{
  "name": "@avinashvelu03/httix",
  "version": "1.0.0",
  "description": "Ultra-lightweight, type-safe, zero-dependency HTTP client built on native Fetch — modern axios replacement.",
  "author": "Avinashvelu03 <avinashvelu03@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Avinashvelu03/httix"
  },
  "homepage": "https://github.com/Avinashvelu03/httix#readme",
  "bugs": {
    "url": "https://github.com/Avinashvelu03/httix/issues"
  },
  "keywords": [
    "http",
    "client",
    "fetch",
    "request",
    "ajax",
    "api",
    "rest",
    "axios",
    "got",
    "ky",
    "http-client",
    "fetch-wrapper",
    "typescript",
    "type-safe",
    "zero-dependency",
    "lightweight",
    "interceptors",
    "retry",
    "timeout",
    "abort",
    "streaming",
    "sse",
    "ndjson",
    "rate-limit",
    "dedup",
    "cache",
    "pagination",
    "middleware",
    "auth",
    "bearer",
    "api-key",
    "universal",
    "node",
    "browser",
    "edge",
    "deno",
    "bun",
    "cloudflare-workers"
  ],
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.cts",
        "default": "./dist/cjs/index.cjs"
      }
    },
    "./plugins": {
      "import": {
        "types": "./dist/esm/plugins/index.d.ts",
        "default": "./dist/esm/plugins/index.js"
      },
      "require": {
        "types": "./dist/cjs/plugins/index.d.cts",
        "default": "./dist/cjs/plugins/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "audit": "npm run lint && npm run typecheck && npm run test:coverage && npm run build",
    "prepublishOnly": "npm run audit",
    "clean": "rm -rf dist coverage",
    "benchmark": "vitest run tests/benchmarks/"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "@vitest/coverage-v8": "^2.1.0",
    "eslint": "^9.16.0",
    "globals": "^17.4.0",
    "prettier": "^3.4.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
